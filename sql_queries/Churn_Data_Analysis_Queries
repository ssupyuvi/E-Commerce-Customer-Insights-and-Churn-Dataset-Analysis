-- 1. Profitability Divergence: AOV Comparison
-- Used to confirm the 'Quality Erosion' finding
SELECT 
    CASE WHEN subscription_status = 'active' THEN 'Active' ELSE 'Churned' END AS group_status,
    COUNT(customer_id) AS total_customers,
    SUM(unit_price * quantity) AS total_revenue,
    AVG(unit_price * quantity) AS avg_order_value
FROM ecommerce_data
GROUP BY 1;

-- 2. Fragility Heatmap: Retention by Revenue Quintile
-- Used to isolate churn concentration by tier
WITH RevenueRank AS (
    SELECT 
        customer_id,
        SUM(unit_price * quantity) AS lifetime_spend,
        NTILE(5) OVER (ORDER BY SUM(unit_price * quantity) DESC) AS revenue_tier
    FROM ecommerce_data
    GROUP BY customer_id
)
SELECT 
    revenue_tier,
    AVG(CASE WHEN subscription_status IN ('cancelled', 'paused') THEN 1.0 ELSE 0.0 END) * 100 AS churn_rate_percent
FROM RevenueRank
GROUP BY revenue_tier
ORDER BY revenue_tier ASC;

-- 3. Behavioral Audit: Cancellation vs. Purchase Frequency Correlation
-- Used to validate the lack of predictive power in current vanity metrics
SELECT 
    cancellations_count,
    AVG(CASE WHEN subscription_status IN ('cancelled', 'paused') THEN 1.0 ELSE 0.0 END) * 100 AS churn_rate_percent
FROM ecommerce_data
GROUP BY cancellations_count;

SELECT 
    purchase_frequency,
    AVG(CASE WHEN subscription_status IN ('cancelled', 'paused') THEN 1.0 ELSE 0.0 END) * 100 AS churn_rate_percent
FROM ecommerce_data
GROUP BY purchase_frequency;

-- 4. Terminal Segment & Risk Assessment (The Value-Engagement Matrix)
-- Used to isolate 'Terminal' (prune) and 'At-Risk' (save) cohorts
WITH CustomerMetrics AS (
    SELECT 
        customer_id,
        SUM(unit_price * quantity) AS total_lifetime_spend,
        purchase_frequency
    FROM ecommerce_data
    GROUP BY customer_id, purchase_frequency
)
SELECT 
    *,
    CASE 
        WHEN total_lifetime_spend < 100 AND purchase_frequency < 2 THEN 'Terminal (Dead)'
        WHEN total_lifetime_spend < 500 AND purchase_frequency >= 2 THEN 'At-Risk'
        ELSE 'Healthy'
    END AS customer_viability_status
FROM CustomerMetrics;
